APP_NAME=business-research-platform
APP_ENV=development

USER_FRONTEND_PORT=5173
ADMIN_FRONTEND_PORT=5174
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

POSTGRES_DB=research_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

REDIS_PORT=6379

JWT_SECRET=change-this-secret-in-real-env
JWT_EXPIRE_MINUTES=120
JWT_ALGORITHM=HS256

DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4.1-mini
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_DISPLAY_NAME=系统管理员

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=90
OPENAI_API_KEY=replace-with-your-openai-api-key

STOCK_LOOKBACK_DAYS=30
